PORT=3000
GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# Use exactly one of these credential options.
# Option A: Raw JSON string from service account key file.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Option B: Base64-encoded full service account JSON.
# GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=ewoJInR5cGUiOiAic2VydmljZV9hY2NvdW50IiwKCS4uLgp9
